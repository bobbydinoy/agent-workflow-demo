# Logging
LOG_LEVEL=INFO

# Data settings
DATA_DIR=./data
NOTES_FILE=company_notes.txt

# External API settings
SEARCH_API_ENDPOINT=https://api.duckduckgo.com/
SEARCH_API_TIMEOUT=8

# Optional LLM settings (enabled by default for local-to-OpenAI fallback)
# If USE_LLM=true but OPENAI_API_KEY is missing/invalid, the app falls back to local notes only
USE_LLM=true
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_API_ENDPOINT=https://api.openai.com/v1/chat/completions
OPENAI_TIMEOUT=20
LLM_WEB_SEARCH=true
LLM_SEARCH_CONTEXT_SIZE=high
LLM_TOOL_ROUTING=true

# Research source controls
ENABLE_PUBLIC_API=true

# Retry settings
MAX_RETRIES=3
RETRY_MIN_WAIT=1
RETRY_MAX_WAIT=8

# Compliance/approval settings
ENABLE_COMPLIANCE_CHECK=true
ENABLE_HUMAN_APPROVAL=true
APPROVAL_MODE=auto
APPROVAL_TOKEN=

# Secret hygiene settings
ENABLE_SECRET_HYGIENE=true
STRICT_SECRET_HYGIENE=false
